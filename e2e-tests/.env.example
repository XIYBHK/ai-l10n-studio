# MidScene AI 模型配置
# 复制此文件为 .env，填入你的密钥

# ── 选项 A：OpenAI（推荐，支持 gpt-4o 视觉）──────────────────────────
MIDSCENE_MODEL_API_KEY=sk-your-openai-key-here
# MIDSCENE_MODEL_NAME=gpt-4o           # 默认即 gpt-4o，可省略
# MIDSCENE_MODEL_FAMILY=openai         # 可省略

# ── 选项 B：DeepSeek Vision（OpenAI 兼容格式）────────────────────────
# MIDSCENE_MODEL_API_KEY=your-deepseek-key
# MIDSCENE_MODEL_BASE_URL=https://api.deepseek.com/v1
# MIDSCENE_MODEL_NAME=deepseek-vl2
# MIDSCENE_MODEL_FAMILY=openai

# ── 选项 C：本地 Qwen3-VL（Ollama / vLLM）───────────────────────────
# MIDSCENE_MODEL_API_KEY=ollama
# MIDSCENE_MODEL_BASE_URL=http://localhost:11434/v1
# MIDSCENE_MODEL_NAME=qwen3-vl
# MIDSCENE_MODEL_FAMILY=openai
