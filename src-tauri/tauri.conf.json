{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "PO-Translator",
  "version": "1.0.0",
  "identifier": "com.potranslator.gui",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost ws://localhost:1420 http://localhost:1420 https://localhost:1420; img-src 'self' data: blob: asset: http://asset.localhost https://asset.localhost; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'; object-src 'none'"
    },
    "windows": [
      {
        "title": "PO 翻译工具",
        "width": 1400,
        "height": 850,
        "minWidth": 1000,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "transparent": true,
        "decorations": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "resources": ["../plugins"]
  },
  "plugins": {}
}
