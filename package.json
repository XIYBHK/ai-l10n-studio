{
  "name": "po-translator-gui",
  "version": "1.0.0",
  "description": "PO鏂囦欢AI缈昏瘧宸ュ叿 - Tauri鐗堟湰",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:portable": "node scripts/portable.js",
    "i18n:check": "node scripts/check-unused-i18n.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "fmt": "cargo fmt --manifest-path ./src-tauri/Cargo.toml",
    "lint:all": "npm run format:check && npm run fmt -- --check",
    "test:e2e:build": "npm run tauri build -- --debug --no-bundle",
    "test:e2e": "npm run test:e2e:build && npm --prefix e2e-tests run test"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@tanstack/react-virtual": "^3.13.18",
    "@tauri-apps/api": "^2.9.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.4",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-store": "^2.4.1",
    "@tauri-apps/plugin-updater": "^2.9.0",
    "@types/lodash": "^4.17.23",
    "@types/react-virtualized-auto-sizer": "^1.0.4",
    "antd": "^6.2.1",
    "i18next": "^25.8.0",
    "immer": "^11.1.3",
    "lodash": "^4.17.23",
    "nanoid": "^5.1.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-draggable": "^4.5.0",
    "react-i18next": "^16.5.3",
    "react-window-infinite-loader": "^2.0.1",
    "swr": "^2.3.8",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.9.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "adm-zip": "^0.5.16",
    "jsdom": "^28.1.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-tauri": "^4.0.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.18.0",
    "npm": ">=9.0.0"
  }
}
